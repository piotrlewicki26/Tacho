# TachoSystem – Generator Licencji
# Skopiuj ten plik jako .env i uzupełnij wartości

# Ścieżka do pliku bazy danych SQLite (domyślnie database/licenses.db)
DATABASE_PATH=

# Sekret używany do podpisywania licencji algorytmem HMAC-SHA256.
# MUSI być identyczny z kluczem skonfigurowanym w głównym systemie TachoSystem.
# Wygeneruj losowy ciąg znaków (min. 32 znaki): openssl rand -hex 32
LICENSE_SECRET=replace_with_strong_random_secret_min_32_characters

# Tryb debugowania (true/false). Ustaw false na produkcji.
APP_DEBUG=false
